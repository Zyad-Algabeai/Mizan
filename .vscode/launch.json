{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: uvicorn (backend)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "jinja": false,
      "justMyCode": true
    },
    {
      "name": "Next.js: dev server (frontend)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Next.js: debug client-side (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "🚀 Mizan: Full stack",
      "configurations": [
        "FastAPI: uvicorn (backend)",
        "Next.js: dev server (frontend)"
      ],
      "stopAll": true
    }
  ]
}
