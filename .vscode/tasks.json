{
  "version": "2.0.0",
  "tasks": [
    {
      // Creates backend\.venv if missing. Safe to run multiple times.
      "label": "backend: create venv",
      "type": "shell",
      "command": "python",
      "args": ["-m", "venv", ".venv"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "windows": {
        "command": "python",
        "args": ["-m", "venv", ".venv"]
      },
      "problemMatcher": []
    },
    {
      // Installs into the venv (never touches system Python).
      "label": "backend: install deps",
      "type": "shell",
      "dependsOn": ["backend: create venv"],
      "command": "${workspaceFolder}/backend/.venv/bin/python",
      "args": ["-m", "pip", "install", "-r", "requirements.txt"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "windows": {
        "command": "${workspaceFolder}\\backend\\.venv\\Scripts\\python.exe",
        "args": ["-m", "pip", "install", "-r", "requirements.txt"]
      },
      "problemMatcher": []
    },
    {
      "label": "backend: run uvicorn",
      "type": "shell",
      "command": "${workspaceFolder}/backend/.venv/bin/uvicorn",
      "args": ["main:app", "--reload", "--port", "8000"],
      "options": { "cwd": "${workspaceFolder}/backend" },
      "windows": {
        "command": "${workspaceFolder}\\backend\\.venv\\Scripts\\uvicorn.exe",
        "args": ["main:app", "--reload", "--port", "8000"]
      },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "mizan",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: install deps",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "frontend: run dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": {
        "panel": "dedicated",
        "group": "mizan",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "🚀 run both (backend + frontend)",
      "dependsOn": ["backend: run uvicorn", "frontend: run dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "install everything",
      "dependsOn": ["backend: install deps", "frontend: install deps"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
